# Copy this file to ".env" on your server and fill in real values.
# (Do NOT commit the real .env — it is git-ignored.)

# GoDaddy / cPanel automatically sets process.env.PORT — do NOT change this.
# For local development only, set a port here (e.g. 3000).
PORT=3000

# Public address of your live site — used to build eSewa return URLs.
# MUST match the domain customers use, e.g. https://www.hoteljailaxmi.com
PUBLIC_BASE_URL=https://www.hoteljailaxmi.com

# Admin login for a FRESH server (your existing local db.json is unaffected)
ADMIN_EMAIL=info.dipendraupadhayay.2005@gmail.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# eSewa. Leave as test until your merchant account is ready, then switch to live.
# You can also set these from the Admin panel (Payment / Bank tab).
ESEWA_MODE=test
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET=8gBm/:&EnhH.1/q(
